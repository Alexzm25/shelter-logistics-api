# -------- App --------
APP_NAME=shelter-logistics-api
APP_CONTAINER_NAME=shelter-logistics-api
APP_WORKDIR=/app
APP_SOURCE_DIR=/app/src
APP_PORT=8000

# Uvicorn
UVICORN_APP=src.main:app
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000

# Python image for build
PYTHON_IMAGE=python:3.12-slim

# -------- PostgreSQL --------
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_CONTAINER_NAME=shelter-logistics-db
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_CONTAINER_PORT=5432
POSTGRES_DB=shelter_logistics
POSTGRES_USER=shelter_user
POSTGRES_PASSWORD=change_me
POSTGRES_DATA_VOLUME=postgres_data

DATABASE_URL=postgresql://shelter_user:change_me@db:5432/shelter_logistics

# -------- IA API --------


# -------- JWT --------

